# OpenAI API key (frontier assistant, memory extraction, moderation, eval judge)
OPENAI_API_KEY="sk-proj-YOUR_OPENAI_KEY_HERE"

# Hugging Face token (OSS model inference)
HF_API_KEY="hf_YOUR_HF_TOKEN_HERE"

# Passkey to reset demo session limits in the UI (keep private, never commit)
DEMO_PASSKEY="your_bson_id_here"

# Set to "false" on HF Spaces to disable file-based telemetry (ephemeral filesystem)
TELEMETRY_ENABLED="true"

# OSS inference provider — change to "nebius" or "together" if hf-inference blocks the model
OSS_PROVIDER="featherless-ai"
